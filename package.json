{
  "name": "steprail",
  "private": true,
  "version": "0.5.6",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --port 8451",
    "dev:server": "node server/index.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.mjs",
    "test": "node --test tests/*.test.mjs",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:e2e": "vite build && playwright test",
    "test:all": "npm run lint && tsc --noEmit && npm run test:unit && npm test"
  },
  "dependencies": {
    "express": "^4.19.2",
    "lucide-react": "^0.454.0",
    "mermaid": "^11.16.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^2.1.9"
  }
}
